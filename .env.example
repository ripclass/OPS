# OPS local defaults: point both app and Docker containers at a local Ollama instance.
LLM_API_KEY=ollama
LLM_BASE_URL=http://localhost:11434/v1
LLM_MODEL_NAME=qwen2.5:7b

# Optional. Leave blank to run the local UI without Zep graph storage.
ZEP_API_KEY=

LLM_BOOST_API_KEY=ollama
LLM_BOOST_BASE_URL=http://localhost:11434/v1
LLM_BOOST_MODEL_NAME=qwen2.5:7b

# Docker uses host.docker.internal so containers can reach Ollama running on Windows.
DOCKER_LLM_API_KEY=ollama
DOCKER_LLM_BASE_URL=http://host.docker.internal:11434/v1
DOCKER_LLM_MODEL_NAME=qwen2.5:7b
DOCKER_LLM_BOOST_API_KEY=ollama
DOCKER_LLM_BOOST_BASE_URL=http://host.docker.internal:11434/v1
DOCKER_LLM_BOOST_MODEL_NAME=qwen2.5:7b

# Optional Supabase persistence for OPS temporal continuity.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Optional frontend links for the OPS wizard and results screen.
VITE_DEMO_MODE=true
VITE_STRIPE_CHECKOUT_URL=
VITE_CALENDLY_URL=
VITE_API_BASE_URL=http://localhost:5001

# Production deployment hints
FRONTEND_ORIGIN=http://localhost:3200
FRONTEND_ORIGINS=
FLASK_DEBUG=true
UPLOAD_FOLDER=
OASIS_SIMULATION_DATA_DIR=
